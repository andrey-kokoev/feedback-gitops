{
  "name": "feedback-gitops",
  "version": "0.1.9",
  "description": "Turn user feedback into GitHub issues via a Cloudflare Worker queue, with a self-hosted mobile-first widget",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "public"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./public/*": "./public/*"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "scripts": {
    "prepare": "tsc -p tsconfig.json",
    "build:widget": "vite build --config widget/vite.config.ts",
    "build:worker": "tsc -p tsconfig.json",
    "build": "pnpm build:widget && pnpm build:worker",
    "dev": "wrangler dev",
    "dev:widget": "vite --config widget/vite.config.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "hono": "^4"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260107.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "pinia": "^2.3.0",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0",
    "wrangler": "^4.66.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/global-maxima/feedback-gitops.git"
  },
  "keywords": [
    "cloudflare-workers",
    "feedback",
    "github-issues",
    "widget"
  ]
}
